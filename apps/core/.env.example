# Copy to .env.local and fill in — .env.local is gitignored.
#
# Runtime DB identity: andes_app (non-superuser) so RLS applies — see
# packages/db/.env.example. Never point the app at the postgres superuser.
DATABASE_URL="postgresql://andes_app:andes_app@localhost:5432/andes?schema=public"
# Generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Object storage — Cloudflare R2 via the S3 API (ADR-008). Private
# bucket; the app only signs URLs. Values from the Cloudflare dashboard:
# R2 → Manage API Tokens (Object Read & Write, scoped to the bucket).
# In Vercel, add via bash printf (never PowerShell pipes — BOM).
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="andes-platform"

# Engineering Copilot — Anthropic via the Vercel AI SDK (ADR-009).
# Key from console.anthropic.com. Model id is config, not code.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

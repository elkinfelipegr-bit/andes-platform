# Copy to .env.local and fill in — .env.local is gitignored.
#
# Runtime DB identity: andes_app (non-superuser) so RLS applies — see
# packages/db/.env.example. Never point the app at the postgres superuser.
DATABASE_URL="postgresql://andes_app:andes_app@localhost:5432/andes?schema=public"
# Generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

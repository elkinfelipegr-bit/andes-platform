# PostgreSQL connection (ADR-001). Copy to .env and fill in locally — .env is gitignored.
# Local dev DB: `docker compose up -d` at the repo root (see docker-compose.yml).
#
# DATABASE_URL — superuser; used by prisma migrate + seed ONLY. Superusers
# bypass RLS, so the running app must never use this in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/andes?schema=public"
# APP_DATABASE_URL — non-superuser runtime identity (RLS applies). Used by
# the RLS integration tests and, in production-shaped setups, the app itself.
APP_DATABASE_URL="postgresql://andes_app:andes_app@localhost:5432/andes?schema=public"

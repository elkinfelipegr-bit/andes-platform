// Sprint 0 domain model — implements docs/architecture/sprint-0-domain-model.md
// Sprint 2 additions (Client, Project) — docs/architecture/sprint-2-domain-model.md
// Multi-tenancy per RFC-001: every tenant-scoped table carries tenantId.
// RLS policies (defense-in-depth layer 2) are applied via raw SQL migrations.

generator client {
  provider = "prisma-client-js"
  // native: local dev machine; rhel-openssl-3.0.x: Vercel serverless runtime
  // (ADR-005) — without it the deployed function has no query engine.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The scope itself — not tenant-scoped (RFC-001: tenant = engineering firm).
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  roles         Role[]
  memberships   Membership[]
  clients       Client[]
  projects      Project[]
  contacts      Contact[]
  proposals     Proposal[]
  proposalItems ProposalItem[]
  inspections   Inspection[]
  findings      Finding[]

  @@map("tenant")
}

// Global identity. Tenant access is exclusively via Membership —
// deliberately no tenantId here (sprint-0-domain-model.md, open question:
// multi-tenant membership stays possible without a migration).
//
// This row IS the Better Auth user (ADR-002: self-hosted, auth data in our
// own DB) — the domain sketch's `authProviderId` is superseded by the
// Account table below, which carries provider linkage per credential/OAuth
// account. emailVerified/image/updatedAt are required by Better Auth.
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  memberships         Membership[]
  sessions            Session[]
  accounts            Account[]
  projectsCreated     Project[]
  proposalsCreated    Proposal[]
  inspectionsAssigned Inspection[] @relation("inspectionsAssigned")
  inspectionsCreated  Inspection[] @relation("inspectionsCreated")

  @@map("user")
}

// ── Better Auth tables (ADR-002) ────────────────────────────────────────
// Not tenant-scoped: sessions/accounts hang off the global User identity;
// tenant + role context is resolved per session via Membership (RFC-001)
// and attached to the session payload in @andes/auth, not stored here.

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String // provider-side id; equals userId for credential accounts
  providerId            String // e.g. "credential", "google"
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String? // hashed, credential provider only
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Roles are data, not an enum (sprint-0-domain-model.md): adding REVIEWER /
// CLIENT_VIEWER later is an insert, not a schema migration.
// Tenant-scoped so a tenant can eventually customize its own role set.
model Role {
  id       String @id @default(cuid())
  tenantId String
  key      String // Sprint 0 seed values: OWNER_ADMIN, ENGINEER
  label    String

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("role")
}

// Join entity: user U holds role R within tenant T.
// "One active tenant per user" is enforced at the application layer, not
// here, so relaxing it later needs no migration (sprint-0-domain-model.md).
model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([tenantId, userId]) // one role per user per tenant in Sprint 0
  @@index([userId])
  @@index([tenantId])
  @@map("membership")
}

// ── Sprint 2: Projects domain (sprint-2-domain-model.md) ────────────────
// ── Sprint 3: CRM enrichment (sprint-3-domain-model.md) ─────────────────

// The tenant's own customer — NOT a tenant (RFC-001 draws this line).
// Born minimal in Sprint 2 as an FK target for Project; enriched in
// Sprint 3 (all additions nullable — additive migration, zero Project
// impact). taxId is free text (NIT validation deferred, jurisdiction-
// agnostic per the SaaS path). archivedAt doubles as flag and audit:
// archived clients keep their projects and stay readable, they only
// leave active pickers.
model Client {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  taxId      String?
  industry   String?
  address    String?
  city       String?
  phone      String?
  email      String?
  notes      String?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects  Project[]
  contacts  Contact[]
  proposals Proposal[]

  @@index([tenantId])
  @@map("client")
}

// A person at a client — the firm's counterpart. Never a platform User
// (contacts don't log in; a future client portal is a separate linkage).
// Carries its own tenantId even though reachable via clientId: RLS must
// not depend on a join (RFC-001). Hard delete is deliberate — address-book
// data, no engineering artifacts attached (sprint-3-domain-model.md, OQ2).
model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String
  name      String
  title     String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  proposals Proposal[]

  @@index([tenantId])
  @@index([clientId])
  @@map("contact")
}

// ── Sprint 4: Proposal Generator (sprint-4-domain-model.md) ─────────────

// Forward-only commercial lifecycle: DRAFT → SENT → ACCEPTED | REJECTED,
// plus SENT → EXPIRED. Decided states are terminal — a revision is a new
// proposal. Enum by the same ratified reasoning as ProjectStatus.
enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("proposal_status")
}

// A commercial offer to a client — the bridge between CRM and Projects.
// Content is editable only in DRAFT (once sent, it is what the client
// saw) and proposals are never hard-deleted: they are the firm's
// commercial record. projectId is stamped by conversion, at most once.
model Proposal {
  id          String         @id @default(cuid())
  tenantId    String
  clientId    String
  contactId   String? // optional recipient — must belong to the client
  projectId   String?        @unique
  code        String // human-assigned, unique per tenant (project precedent)
  title       String
  scope       String?
  currency    String         @default("COP")
  validUntil  DateTime?
  status      ProposalStatus @default(DRAFT)
  createdById String // audit only — authorization flows from Membership
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contact   Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     ProposalItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([clientId])
  @@map("proposal")
}

// One priced line of the offer. Money is exact Decimal, never float;
// totals are computed from items, never stored (single source of truth).
// Carries its own tenantId — RLS never depends on a join (RFC-001).
model ProposalItem {
  id          String  @id @default(cuid())
  tenantId    String
  proposalId  String
  position    Int
  description String
  quantity    Decimal @db.Decimal(14, 2)
  unit        String // m², un, global, …
  unitPrice   Decimal @db.Decimal(14, 2)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([proposalId])
  @@map("proposal_item")
}

// Lifecycle states are platform workflow constants (ratified: enum, not a
// data table — unlike Role, tenants do not customize these).
enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED

  @@map("project_status")
}

// The container all engineering work attaches to. Never hard-deleted —
// lifecycle ends at ARCHIVED (sprint-2-domain-model.md, process 5).
model Project {
  id          String        @id @default(cuid())
  tenantId    String
  clientId    String? // optional: internal/R&D work has no client
  code        String // human-assigned, unique per tenant (e.g. P-2026-014)
  name        String
  description String?
  status      ProjectStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  createdById String // audit only — authorization flows from Membership
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  proposal    Proposal? // the accepted proposal this project was converted from
  inspections Inspection[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([clientId])
  @@map("project")
}

// ── Sprint 5: Inspection Module (sprint-5-domain-model.md) ──────────────

// Forward-only: SCHEDULED → COMPLETED | CANCELLED. Content editable only
// while SCHEDULED — a completed inspection is what the inspector reported.
enum InspectionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED

  @@map("inspection_status")
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("finding_severity")
}

// A site visit within a project — the first engineering record attached
// to the Sprint 2 project container. inspectorId references a User whose
// tenant Membership the API verifies (a userId alone proves nothing).
// Never hard-deleted: CANCELLED is the terminal state for visits that
// didn't happen.
model Inspection {
  id           String           @id @default(cuid())
  tenantId     String
  projectId    String
  inspectorId  String
  code         String // human-assigned, unique per tenant (precedent)
  title        String
  scheduledFor DateTime
  performedAt  DateTime? // stamped by completion
  notes        String?
  status       InspectionStatus @default(SCHEDULED)
  createdById  String // audit only — authorization flows from Membership
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspector User      @relation("inspectionsAssigned", fields: [inspectorId], references: [id], onDelete: Restrict)
  createdBy User      @relation("inspectionsCreated", fields: [createdById], references: [id], onDelete: Restrict)
  findings  Finding[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([projectId])
  @@index([inspectorId])
  @@map("inspection")
}

// One observation from the visit — the ProposalItem pattern applied to
// field data. Own tenantId: RLS never depends on a join (RFC-001).
model Finding {
  id           String          @id @default(cuid())
  tenantId     String
  inspectionId String
  position     Int
  description  String
  severity     FindingSeverity
  location     String?

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([inspectionId])
  @@map("finding")
}
